# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here
# Optional: override base URL for Azure/proxy/LiteLLM (leave blank for standard OpenAI)
OPENAI_BASE_URL=

# Models
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Data
DATA_PATH=./data/telecom_incidents.csv

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Search
TOP_K=10
RRF_K=60

# LangSmith tracing (optional — set LANGCHAIN_TRACING_V2=false to disable)
LANGCHAIN_API_KEY=lsv2_pt_your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=telecom-fault-intel
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
